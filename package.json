{
  "name": "tvwjob5",
  "version": "1.0.0",
  "private": true,
  "description": "tvw \u2014 tk-dcb framework + Nuxt + tRPC WebSocket (barebones)",
  "scripts": {
    "clean": "find . -type d \\( -name 'dist' -o -name '.nuxt' -o -name '.output' \\) ! -path '*/node_modules/*' -exec rm -rf {} + 2>/dev/null || true",
    "dev": "pnpm run dev:kill; turbo run dev --parallel",
    "dev:kill": "bash scripts/dev-kill.sh",
    "dev:frontend": "pnpm --filter tvw-frontend dev",
    "dev:domain": "pnpm --filter tvw-domain dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "overrides": {
      "@nuxt/kit": "^4.2.1"
    },
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "@parcel/watcher"
    ]
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
