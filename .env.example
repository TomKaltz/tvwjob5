# Copy to .env at repo root and adjust values.
# Nuxt loads env from packages/tvw-frontend/.env — that path is a symlink to ../../.env (committed).
#
# @tk-dcb/framework: root package.json uses pnpm.overrides with
# file:../../2025/tk-dcb/packages/tk-dcb-framework for local dev.
# For OneDev-only installs, remove that override and set the registry token in .npmrc (see comments there).

# Postgres (same DB for DCB event store + tvw_users)
# Either set DATABASE_URL, or all of DB_* below.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tvw

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tvw
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# DCB events table name (avoid colliding with other apps on same cluster)
TVW_EVENTS_TABLE=tvw_events

# HS256 signing secret for login JWT (used by WebSocket connectionParams + /api/auth/me)
AUTH_SECRET=dsfasdfdfasdfasdge33432532523t2ef

# Optional: create first user when tvw_users is empty (development only)
# TVW_BOOTSTRAP_USERNAME=admin
# TVW_BOOTSTRAP_PASSWORD=changeme

# Optional: override public WS URL (default same-origin /ws)
# NUXT_PUBLIC_TRPC_WS_URL=

# Optional: @tk-dcb/nuxt + tRPC client console.debug (set to 1)
# NUXT_PUBLIC_TK_DCB_DEBUG=1
